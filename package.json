{
  "name": "@zvonimirsun/iszy-common",
  "type": "module",
  "author": "ZvonimirSun",
  "license": "MIT",
  "version": "1.1.4",
  "packageManager": "pnpm@11.1.3",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./*": "./*"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "./dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "up": "taze minor -I"
  },
  "dependencies": {
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "eslint": "^10.4.0",
    "taze": "^19.13.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.13"
  }
}
